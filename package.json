{
    "name": "despedida-sophie-quizz",
    "version": "1.0.0",
    "description": "Quizz interativo para a Despedida de Solteira da Sophie — o Nardinho responde em vídeo!",
    "private": true,
    "scripts": {
        "build": "esbuild src/main.ts --bundle --outfile=public/app.bundle.js --platform=browser --target=es2020 --minify",
        "dev": "esbuild src/main.ts --bundle --outfile=public/app.bundle.js --platform=browser --target=es2020 --watch",
        "typecheck": "tsc --noEmit",
        "lint": "eslint src/**/*.ts",
        "lint:fix": "eslint src/**/*.ts --fix",
        "format": "prettier --write src/**/*.ts public/*.html public/*.css",
        "prepare": "husky"
    },
    "keywords": [
        "bachelorette",
        "quiz",
        "sophie",
        "nardinho"
    ],
    "author": "Beatriz S. Oliveira",
    "license": "MIT",
    "devDependencies": {
        "@commitlint/cli": "^19.0.0",
        "@commitlint/config-conventional": "^19.0.0",
        "@typescript-eslint/eslint-plugin": "^8.0.0",
        "@typescript-eslint/parser": "^8.0.0",
        "esbuild": "^0.25.0",
        "eslint": "^9.0.0",
        "husky": "^9.0.0",
        "prettier": "^3.0.0",
        "typescript": "^5.5.0"
    }
}
